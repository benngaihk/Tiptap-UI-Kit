# Tiptap AI Configuration
# Copy this file to .env and fill in your values
#
# SECURITY NOTE: VITE_* variables are inlined into the client bundle at build
# time — any key you put here ships to every browser. Only use keys you own
# with a spending limit, or point VITE_AI_BASE_URL at your own backend proxy
# that holds the real key server-side.

# AI Provider: openai | deepseek | anthropic | aliyun | ollama | custom
VITE_AI_PROVIDER=openai

# API Key (required for most providers)
# Get your API key from your provider's dashboard
VITE_AI_API_KEY=your-api-key-here

# API Secret (required for Aliyun)
# VITE_AI_API_SECRET=

# Base URL (optional, uses default for each provider)
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com
# Anthropic: https://api.anthropic.com/v1
# Aliyun: https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama: http://localhost:11434/v1
# VITE_AI_BASE_URL=

# Model (optional, uses default for each provider)
# OpenAI: gpt-4o, gpt-4o-mini
# DeepSeek: deepseek-chat, deepseek-coder
# Anthropic: claude-3-5-sonnet-20241022
# Aliyun: qwen-turbo, qwen-plus, qwen-max
# Ollama: llama3.2, mistral, codellama
# VITE_AI_MODEL=

# Temperature (optional, default: 0.7)
# VITE_AI_TEMPERATURE=0.7

# Max tokens (optional, default: 2048)
# VITE_AI_MAX_TOKENS=2048

# ===== Collaboration Configuration =====
# WebSocket URL for y-websocket collaboration
# Required if you enable collaboration feature in editor
# VITE_COLLABORATION_WS_URL=wss://your-server.com/ws
